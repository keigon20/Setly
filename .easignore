# Creating this file makes EAS Build stop reading .gitignore for archiving,
# so every pattern below must be listed explicitly even if it duplicates
# .gitignore - nothing here is redundant.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by prebuild; EAS regenerates these from app.config.js)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
bugreport-*.zip

# macOS
.DS_Store
*.pem

# local env files (EAS Environment Variables are used instead)
.env
.env*
.env*.local

# typescript
*.tsbuildinfo

# tooling / VCS, not needed to build the app
.git/
.claude/
.firebase/

# local build artifacts, never upload these
build-*.aab
build-*.ipa
build-*.apk

# separate Next.js website project, not part of the mobile app build
web/
