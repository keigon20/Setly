rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/config/admins).data.uids.hasAny([request.auth.uid]);
    }

    function isFriendOf(otherUserId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(otherUserId));
    }

    function isOwnerOrFriendOfEvent(eventId) {
      let ownerId = get(/databases/$(database)/documents/events/$(eventId)).data.userId;
      return request.auth.uid == ownerId || isFriendOf(ownerId);
    }

    function isEventOwner(eventId) {
      return request.auth.uid == get(/databases/$(database)/documents/events/$(eventId)).data.userId;
    }

    function isBlockedEitherWay(otherUserId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/blockedUsers/$(otherUserId))
        || exists(/databases/$(database)/documents/users/$(otherUserId)/blockedUsers/$(request.auth.uid));
    }

    // User profiles - any signed-in user can look others up (needed for email search,
    // friend names, and feed attribution). Only the owner can write their own profile.
    // Admins can update (e.g. setting suspendedUntil) but not create or delete.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();

      match /friends/{friendId} {
        allow read: if request.auth.uid == userId;
        // friendId can create only when userId sent them a friend request (prevents injection).
        // friendId can update their own display name entry and delete (unfriend from their side).
        allow create: if request.auth.uid == userId
          || (request.auth.uid == friendId
              && exists(/databases/$(database)/documents/friendRequests/$(userId + '_' + friendId)));
        allow update, delete: if request.auth.uid == userId || request.auth.uid == friendId;
      }

      match /blockedUsers/{blockedId} {
        allow read, create, delete: if request.auth.uid == userId;
      }
    }

    // Friend requests - either party can read; only the sender can create, and not if
    // either side has blocked the other; either party can delete (decline / cleanup).
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create: if request.resource.data.fromUserId == request.auth.uid
        && !isBlockedEitherWay(request.resource.data.toUserId);
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
    }

    // Events - owner has full access; friends can read only if not hidden; admins can read any.
    match /events/{eventId} {
      allow read: if request.auth.uid == resource.data.userId
        || (resource.data.isHidden == false && isFriendOf(resource.data.userId))
        || isAdmin();
      allow create: if request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId || isAdmin();
      allow delete: if request.auth.uid == resource.data.userId;

      match /likes/{likerId} {
        allow read: if request.auth.uid == likerId || isOwnerOrFriendOfEvent(eventId);
        allow create, update: if request.auth.uid == likerId && isOwnerOrFriendOfEvent(eventId);
        allow delete: if request.auth.uid == likerId || isEventOwner(eventId);
      }

      match /comments/{commentId} {
        allow read: if request.auth.uid == resource.data.userId || isOwnerOrFriendOfEvent(eventId);
        allow create: if request.resource.data.userId == request.auth.uid && isOwnerOrFriendOfEvent(eventId);
        allow delete: if request.auth.uid == resource.data.userId || isEventOwner(eventId);

        match /likes/{likerId} {
          allow read: if request.auth.uid == likerId || isOwnerOrFriendOfEvent(eventId);
          allow create, update: if request.auth.uid == likerId && isOwnerOrFriendOfEvent(eventId);
          allow delete: if request.auth.uid == likerId || isEventOwner(eventId);
        }

        match /replies/{replyId} {
          allow read: if request.auth.uid == resource.data.userId || isOwnerOrFriendOfEvent(eventId);
          allow create: if request.resource.data.userId == request.auth.uid && isOwnerOrFriendOfEvent(eventId);
          allow delete: if request.auth.uid == resource.data.userId || isEventOwner(eventId);
        }
      }
    }

    // Notifications - owner can read and mark as read; signed-in users can create
    // but must identify themselves as the sender (prevents impersonation).
    // Admins can create system notifications (fromUserId: 'system') on behalf of Setly.
    match /notifications/{userId}/items/{itemId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if isSignedIn() && (request.resource.data.fromUserId == request.auth.uid || isAdmin());
    }

    // Config - read-only for signed-in users; admins can write (banned emails management).
    // config/admins holds { uids: ['uid1', ...] }; config/bannedEmails holds { emails: [...] }.
    match /config/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reports - anyone can file one; only admins can read or update (change status).
    match /reports/{reportId} {
      allow create: if request.resource.data.reporterId == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Bug reports - anyone can file one; only admins can read them.
    match /bugReports/{reportId} {
      allow create: if request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Giveaways - any signed-in user can read; only admins can create/update/delete.
    // Each user can record their own entry in the entries subcollection.
    match /giveaways/{giveawayId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /entries/{userId} {
        allow read: if isSignedIn();
        allow create: if request.auth.uid == userId;
        allow delete: if request.auth.uid == userId || isAdmin();
      }
    }

    // Account-deletion collectionGroup rules — allow a user to query and delete
    // their own scattered content (comments/replies/likes on others' events,
    // giveaway entries) without get() lookups that would fail in collectionGroup
    // context. Access is limited to documents where userId == the caller.
    match /{path=**}/comments/{commentId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /{path=**}/replies/{replyId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /{path=**}/likes/{likeId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /{path=**}/entries/{entryId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
